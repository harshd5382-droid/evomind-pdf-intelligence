# =====================================================
# EvoMind PDF Intelligence - environment configuration
# Copy to .env and fill in the providers you intend to use.
# =====================================================

# --- LLM provider ---
# nvidia | anthropic | openai | gemini | ollama
PRIMARY_PROVIDER=nvidia

# NVIDIA NIM (build.nvidia.com — free OpenAI-compatible endpoint).
# Get a key at: https://build.nvidia.com/settings/api-keys
# Suggested catalog (pick one for NVIDIA_MODEL):
#   deepseek-ai/deepseek-v4-pro          (strongest, supports thinking)
#   deepseek-ai/deepseek-r1              (reasoning)
#   z-ai/glm-5.1                          (general, supports thinking)
#   nvidia/nemotron-3-super-120b-a12b    (NVIDIA's own, supports thinking)
#   google/gemma-4-31b-it                 (open Google model)
#   meta/llama-3.3-70b-instruct           (no thinking)
NVIDIA_API_KEY=
NVIDIA_API_KEY_BACKUP=
NVIDIA_API_KEY_BACKUPS=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro
NVIDIA_THINKING=true
NVIDIA_REASONING_EFFORT=max
# NVIDIA embedding model (used when EMBEDDING_PROVIDER=nvidia).
# Suggested: nvidia/nv-embedqa-e5-v5 (1024 dim, retrieval-tuned, recommended)
#            nvidia/nv-embedqa-mistral-7b-v2 (4096 dim, strongest, slower)
#            snowflake/arctic-embed-l (1024 dim)
#            baai/bge-m3 (1024 dim)
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1


# Groq (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# --- Embeddings: nvidia | local (sentence-transformers) | openai ---
EMBEDDING_PROVIDER=nvidia

# --- PDF parser fallback chain (priority order) ---
PARSER_PRIORITY=llamaparse,pymupdf,pdfplumber
LLAMAPARSE_API_KEY=

# --- Ingest worker pool (used when Celery is unavailable) ---
# Parallel threads ingesting PDFs. Free NVIDIA tier: keep at 2 (≈40 req/min budget).
INGEST_WORKERS=2

# --- Autopilot (in-process continuous research loop) ---
# When ON, the API process self-runs every research phase on a cadence — no
# manual "Run Cycle" click. Your only job is to put PDFs in the drop folder.
AUTOPILOT_ENABLED=true
AUTOPILOT_SOLVE_INTERVAL_SEC=45        # drain N open questions every 45s
AUTOPILOT_SOLVE_BATCH=3                # questions per pass (each = 2 LLM calls)
AUTOPILOT_SEED_INTERVAL_SEC=60         # scan for unseeded docs every 60s
AUTOPILOT_SYNTHESIS_INTERVAL_SEC=900   # cross-document synthesis every 15 min
AUTOPILOT_HYPOTHESIS_INTERVAL_SEC=1800 # generate hypotheses every 30 min
AUTOPILOT_CONTRADICTIONS_INTERVAL_SEC=1200  # contradiction sweep every 20 min
AUTOPILOT_SCORE_INTERVAL_SEC=300       # refresh intelligence snapshot every 5 min

# --- Auto-ingest folder watcher ---
# Drop PDFs (or whole folders) into AUTO_INGEST_DIR — the API picks them up,
# ingests, seeds questions, and the autopilot reasons over them. No upload UI
# needed. Re-runs are idempotent (already-ingested files skipped by absolute path).
AUTO_INGEST_ENABLED=true
AUTO_INGEST_DIR=./data/dropbox
AUTO_INGEST_INTERVAL_SEC=10            # how often to re-scan the folder
AUTO_INGEST_STABLE_SEC=2.0             # file mtime must be still this long before pickup

# --- Autonomy knobs ---
QUESTIONS_PER_DOC=10
RECURSION_DEPTH=2
AUTONOMY_LEVEL=balanced
CREATIVITY=0.6
CONFIDENCE_THRESHOLD=0.55

# --- Infra (defaults match docker-compose) ---
POSTGRES_DSN=postgresql+psycopg://evomind:evomind@localhost:5432/evomind
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=evomind123

LOG_LEVEL=INFO
